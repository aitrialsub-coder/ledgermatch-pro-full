{
  "manifest_version": 3,
  "name": "LedgerMatch Pro",
  "version": "1.0.0",
  "description": "Dual-ledger reconciliation with OCR. No AI \u2014 pure algorithmic matching.",
  "permissions": [
    "sidePanel",
    "storage",
    "offscreen",
    "activeTab"
  ],
  "action": {
    "default_title": "Open LedgerMatch Pro",
    "default_icon": {
     "16": "public/icons/icon16.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "tessdata/*",
        "opencv.js",
        "tesseract-worker.js",
        "tesseract-core.wasm.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
